# Backend API URL — change to your production API URL when deploying
VITE_API_URL=http://localhost:3000/api

# Fantasy 7 feature flag (frontend routes and UI)
VITE_FEATURE_FANTASY7_ENABLED=false

# Ladder lockout cutoff (ISO-8601 with timezone)
# Example: 2026-03-10T00:00:00+11:00
VITE_CUTOFF_AT=2026-03-10T00:00:00+11:00

# Grand final date/time (used for "season over" window)
VITE_GRAND_FINAL_AT=2026-09-26T17:30:00+10:00

# Optional manual override (normally leave unset)
# true  = force locked
# false = force unlocked
# VITE_COMPETITION_LOCKED=false
